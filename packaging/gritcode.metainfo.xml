<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.gritcode.app</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0</project_license>

  <name>Gritcode</name>
  <summary>Native desktop AI coding assistant</summary>

  <developer id="com.devmindscape">
    <name>DevMindscape</name>
  </developer>

  <description>
    <p>
      A fast, native desktop AI coding assistant. Streaming markdown
      rendering, multi-session history with full-text search, and a
      one-click Play button that builds and runs your project without
      an AI roundtrip.
    </p>
    <p>
      Lean and fast: a fraction of the size of Electron-based alternatives
      like OpenCode, Claude Code, and Codex. Built with C++20 and wxWidgets.
    </p>
    <p>
      Supports DeepSeek V4 (API key) or the free OpenCode Zen tier.
    </p>
  </description>

  <launchable type="desktop-id">gritcode.desktop</launchable>

  <icon type="remote">https://raw.githubusercontent.com/lszl84/gritcode/main/assets/gritcode-icon.svg</icon>
